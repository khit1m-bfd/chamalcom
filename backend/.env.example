# ─── ENVIRONMENT ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── DATABASE ────────────────────────────────────────────────────────────────────
DATABASE_URL="mysql://root@localhost:3306/chamalcom_db"

# ─── JWT ─────────────────────────────────────────────────────────────────────────
# Minimum 64 characters each
JWT_ACCESS_SECRET=your_access_secret_min_64_chars_replace_this_with_a_secure_random_string
JWT_REFRESH_SECRET=your_refresh_secret_min_64_chars_replace_this_with_a_secure_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── CLOUDINARY ──────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── EMAIL (Nodemailer) ───────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=chamalcom@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM="ChamalCom <noreply@chamalcom.ma>"

# ─── FRONTEND ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── BUSINESS RULES ──────────────────────────────────────────────────────────────
COMMISSION_RATE=10
MAX_IMAGES_PER_APPART=15
MAX_IMAGE_SIZE_MB=5
